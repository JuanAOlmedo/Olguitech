<%= form_with model: @newsletter do |form| %>
    <div class="form">
        <div class="field" data-controller="counter">
            <%= form.label :title, 'Título' %>
            <%= form.text_area :title,
                maxlength: 60,
                data: {
                  counter_target: "content",
                  action: "input->counter#updateCounter"
                } %>
            <div style="text-align: right;">
                <span data-counter-target="counter">0/60</span>
            </div>
        </div>

        <div class="field" data-controller="counter">
            <%= form.label :subject, 'Asunto' %>
            <%= form.text_area :subject,
                maxlength: 60,
                data: {
                  counter_target: "content",
                  action: "input->counter#updateCounter"
                } %>
            <div style="text-align: right;">
                <span data-counter-target="counter">0/60</span>
            </div>
        </div>

        <div class="rich-text field">
            <%= form.label :content, 'Contenido' %>
            <%= form.rich_text_area :content %>
        </div>

        <div class="btn-group" style="margin: auto;">
            <%= form.check_box :sent, class: 'btn-check' %>
            <%= form.label :sent, 'Enviar al crear', class: 'btn' %>

            <%= form.submit 'Crear', class: 'btn centered' %>
        </div>
    </div>
<% end %>
